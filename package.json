{
  "name": "@wasm-oj/forge",
  "version": "0.1.0",
  "description": "Deterministic, local-first WASI and WASIX compiler and judge library powered by Wasmer.",
  "license": "MIT",
  "author": "JacobLinCool",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wasm-oj/forge.git"
  },
  "homepage": "https://github.com/wasm-oj/forge#readme",
  "bugs": {
    "url": "https://github.com/wasm-oj/forge/issues"
  },
  "keywords": [
    "online-judge",
    "wasi",
    "wasix",
    "wasm",
    "wasmer"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "packageManager": "pnpm@10.21.0",
  "types": "./lib/core.d.ts",
  "exports": {
    ".": {
      "types": "./lib/core.d.ts",
      "import": "./lib/core.js"
    },
    "./browser": {
      "types": "./lib/browser.d.ts",
      "import": "./lib/browser.js"
    },
    "./server": {
      "types": "./lib/server.d.ts",
      "import": "./lib/server.js"
    },
    "./toolchain-cache-sw.js": "./public/toolchain-cache-sw.js",
    "./toolchains/clang-22.0.0-git20542-10.cc1-pins.json": "./public/toolchains/clang-22.0.0-git20542-10.cc1-pins.json",
    "./toolchains/clang-22.0.0-git20542-10.manifest.json": "./public/toolchains/clang-22.0.0-git20542-10.manifest.json",
    "./toolchains/clang-22.0.0-git20542-10.libcxx-pch.json": "./public/toolchains/clang-22.0.0-git20542-10.libcxx-pch.json",
    "./toolchains/clang-22.0.0-git20542-10.cpp-debug.pch.gz.bin": "./public/toolchains/clang-22.0.0-git20542-10.cpp-debug.pch.gz.bin",
    "./toolchains/clang-22.0.0-git20542-10.cpp-release.pch.gz.bin": "./public/toolchains/clang-22.0.0-git20542-10.cpp-release.pch.gz.bin",
    "./toolchains/clang-22.0.0-git20542-10.webc.gz.bin": "./public/toolchains/clang-22.0.0-git20542-10.webc.gz.bin",
    "./toolchains/go-1.26.5-wasip1.manifest.json": "./public/toolchains/go-1.26.5-wasip1.manifest.json",
    "./toolchains/go-1.26.5-wasip1.stdlib.gz.bin": "./public/toolchains/go-1.26.5-wasip1.stdlib.gz.bin",
    "./toolchains/go-1.26.5-wasip1.webc.gz.bin": "./public/toolchains/go-1.26.5-wasip1.webc.gz.bin",
    "./toolchains/python-3.14.6-wasip1.manifest.json": "./public/toolchains/python-3.14.6-wasip1.manifest.json",
    "./toolchains/python-3.14.6-wasip1.webc.gz.bin": "./public/toolchains/python-3.14.6-wasip1.webc.gz.bin",
    "./toolchains/quickjs-0.15.1.wasm.gz.bin": "./public/toolchains/quickjs-0.15.1.wasm.gz.bin",
    "./toolchains/rust-1.91.1-dev.manifest.json": "./public/toolchains/rust-1.91.1-dev.manifest.json",
    "./toolchains/rust-1.91.1-dev.webc.gz.bin": "./public/toolchains/rust-1.91.1-dev.webc.gz.bin",
    "./toolchains/typescript-7.0.2.wasm.gz.bin": "./public/toolchains/typescript-7.0.2.wasm.gz.bin",
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "public/toolchain-cache-sw.js",
    "public/toolchains",
    "rust-toolchain.toml",
    "pnpm-lock.yaml",
    "crates/runtime-core/Cargo.lock",
    "crates/runtime-core/Cargo.toml",
    "crates/runtime-core/README.md",
    "crates/runtime-core/src",
    "vendor/shared-buffer/Cargo.toml",
    "vendor/shared-buffer/LICENSE_APACHE.md",
    "vendor/shared-buffer/LICENSE_MIT.md",
    "vendor/shared-buffer/README.md",
    "vendor/shared-buffer/src",
    "vendor/virtual-fs/Cargo.toml",
    "vendor/virtual-fs/LICENSE",
    "vendor/virtual-fs/src",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "licenses",
    "docs",
    "experiments"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/build-site.ts",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log node scripts/start-production.mjs",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "node node_modules/typescript/lib/tsc.js --noEmit",
    "lint": "eslint .",
    "assets:og": "node scripts/render-og.mjs",
    "library:build": "node scripts/build-library.mjs",
    "library:verify": "pnpm run contract:verify && pnpm run package-manager:verify && pnpm run docs:verify && pnpm run github:verify && pnpm run conformance:verify && pnpm run licenses:verify && pnpm run runtime:licenses:verify && pnpm run toolchain:verify && pnpm run wasmer-sdk:verify && node scripts/verify-library.mjs && node scripts/verify-library-nodenext.mjs",
    "prepack": "pnpm run library:build && pnpm run library:verify",
    "runtime:build": "bash scripts/build-runtime-core.sh",
    "runtime:build-native": "cargo build --locked --manifest-path crates/runtime-core/Cargo.toml --release --bins",
    "runtime:test": "cargo test --locked --manifest-path crates/runtime-core/Cargo.toml",
    "runtime:check-web": "cargo check --locked --manifest-path crates/runtime-core/Cargo.toml --target wasm32-unknown-unknown --no-default-features --features web",
    "runtime:licenses:generate": "bash scripts/generate-runtime-licenses.sh",
    "runtime:licenses:verify": "node scripts/verify-runtime-licenses.mjs",
    "wasmer-sdk:licenses:generate": "bash scripts/generate-wasmer-sdk-licenses.sh",
    "components:generate": "node scripts/generate-third-party-components.mjs",
    "licenses:verify": "node scripts/verify-third-party-licenses.mjs",
    "contract:verify": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/verify-contract.mjs",
    "package-manager:verify": "node scripts/verify-package-manager.mjs",
    "docs:verify": "node scripts/verify-docs.mjs",
    "github:verify": "node scripts/verify-github-workflows.mjs",
    "conformance:server": "FORGE_RUN_CONFORMANCE=1 vitest run --config vitest.config.ts src/server/conformance.integration.test.ts --reporter=verbose",
    "conformance:browser": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/run-browser-conformance.mjs",
    "conformance:compare": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/compare-conformance.ts",
    "conformance:verify": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/verify-conformance.mjs",
    "release:verify": "node scripts/verify-release.mjs",
    "ci:verify": "pnpm run github:verify && pnpm run conformance:verify && pnpm run typecheck && pnpm run lint && pnpm test && pnpm run library:build && pnpm run library:verify && pnpm run build && pnpm run runtime:test && pnpm run runtime:check-web",
    "judge:integration": "FORGE_RUN_JUDGE_INTEGRATION=1 vitest run --config vitest.config.ts src/server/judge.integration.test.ts --reporter=verbose",
    "cost-baseline:calibrate": "FORGE_RUN_COST_BASELINE=1 vitest run --config vitest.config.ts src/server/cost-baseline.integration.test.ts --reporter=verbose",
    "cost-baseline:transform": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/transform-cost-baselines.mjs",
    "toolchain:browser:prepare": "bash scripts/build-browser-toolchains.sh",
    "toolchain:rust:prepare": "node scripts/package-rust-toolchain.mjs",
    "toolchain:go:prepare": "node scripts/package-go-toolchain.mjs",
    "toolchain:python:prepare": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/prepare-python-toolchain.mjs",
    "toolchain:clang:prepare": "node scripts/package-clang-toolchain.mjs",
    "toolchain:clang:pch": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/build-clang-libcxx-pch.ts",
    "toolchain:verify": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/verify-toolchains.mjs",
    "wasmer-sdk:verify": "node scripts/verify-wasmer-sdk-init.mjs",
    "clean": "node scripts/clean.mjs"
  },
  "dependencies": {
    "@wasmer/sdk": "0.10.0",
    "es-module-lexer": "2.3.1",
    "fflate": "0.8.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@monaco-editor/react": "4.7.0",
    "@types/node": "22.19.19",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.28",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "fake-indexeddb": "6.2.5",
    "js-yaml": "4.3.0",
    "lucide-react": "1.25.0",
    "monaco-editor": "0.52.2",
    "next": "16.2.10",
    "playwright": "1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-server-dom-webpack": "19.2.7",
    "rollup": "4.62.2",
    "rollup-plugin-dts": "6.4.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  }
}
